{
    "functions": {
        "api/index.py": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ],
    "build": {
        "env": {
            "REQUIREMENTS_FILE": "requirements-vercel.txt"
        }
    }
}